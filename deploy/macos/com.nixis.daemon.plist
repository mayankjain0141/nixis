<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.nixis.daemon</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/nixis-daemon</string>
        <string>-policy-dir</string>
        <string>/etc/nixis/policies</string>
        <string>-audit-db</string>
        <string>/var/lib/nixis/audit.db</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>
    <key>ThrottleInterval</key>
    <integer>5</integer>
    <key>StandardOutPath</key>
    <string>/var/log/nixis/daemon.log</string>
    <key>StandardErrorPath</key>
    <string>/var/log/nixis/daemon.err</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>NIXIS_SOCKET_PATH</key>
        <string>/tmp/nixis.sock</string>
    </dict>
</dict>
</plist>

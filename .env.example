# LLM proxy for policy translation (optional — only needed for `nixis import`)
LITELLM_API_KEY=your-api-key-here
LITELLM_BASE_URL=https://your-llm-proxy.example.com/v1

# PostgreSQL connection (optional — only needed if using audit persistence)
# NIXIS_PG_URL=postgres://nixis@localhost:5432/nixis?sslmode=disable

# OpenTelemetry (optional — traces + metrics exported via OTLP gRPC)
# Set to any OTLP gRPC endpoint to enable. Absent = noop (default).
# Compatible with Jaeger, Grafana Tempo, OpenTelemetry Collector, Honeycomb, etc.
# NIXIS_OTEL_ENDPOINT=localhost:4317

# Dashboard WebSocket server (default: :9090)
# NIXIS_DASHBOARD_ADDR=:9090

# Dashboard (Vite build — required for production builds, optional for dev)
VITE_DAEMON_URL=http://localhost:9090

# gRPC ext_authz listener (optional — for Envoy/Istio integration)
# NIXIS_GRPC_ADDR=:9091

# Aegis Environment Configuration
# Copy to .env and fill in real values: cp .env.example .env
# .env is gitignored and must never be committed.

# LLM Intent Classifier (optional — required only if using the intent_llm layer)
# Set to any OpenAI-compatible endpoint (OpenAI, Anthropic, Ollama, etc.)
LITELLM_BASE_URL=https://api.openai.com/v1
LITELLM_API_KEY=your-api-key-here
LITELLM_MODEL=gpt-4o-mini

# Alternatively, use provider keys directly (no proxy needed):
# OPENAI_API_KEY=your-openai-key
# ANTHROPIC_API_KEY=your-anthropic-key

# PostgreSQL (optional — for structured telemetry storage)
AEGIS_PG_URL=postgres://aegis:change-me@localhost:5432/aegis?sslmode=disable
POSTGRES_PASSWORD=change-me

# Daemon configuration
AEGIS_SOCKET=/tmp/aegis.sock
AEGIS_HTTP_PORT=8080
AEGIS_POLICY_PATH=policies/default.yaml
AEGIS_MODE=enforce
AEGIS_LOG_LEVEL=info

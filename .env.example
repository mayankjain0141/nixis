# LLM proxy for policy translation (optional — only needed for `aegis import`)
LITELLM_API_KEY=your-api-key-here
LITELLM_BASE_URL=https://your-llm-proxy.example.com/v1

# PostgreSQL connection (optional — only needed if using audit persistence)
# AEGIS_PG_URL=postgres://aegis@localhost:5432/aegis?sslmode=disable

# Aegis Environment Configuration
# Copy to .env and fill in real values: cp .env.example .env

# LiteLLM Proxy (for demo agent)
LITELLM_API_KEY=your-litellm-api-key-here
LITELLM_BASE_URL=https://your-litellm-proxy.example.com

# PostgreSQL (for trace storage)
AEGIS_PG_URL=postgres://aegis:aegis@localhost:5432/aegis?sslmode=disable

# Daemon configuration
AEGIS_SOCKET=/tmp/aegis.sock
AEGIS_HTTP_PORT=8080
AEGIS_POLICY_PATH=policies/default.yaml
AEGIS_MODE=enforce
AEGIS_LOG_LEVEL=info

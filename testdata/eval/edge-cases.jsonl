{"id": "edge-parser-empty-command", "category": "parser_stress", "tool": "shell_exec", "arguments": "{\"command\": \"\"}", "expected_action": "allow", "description": "Empty command string", "difficulty": "medium", "notes": "Empty input should not crash parser or trigger any deny rule"}
